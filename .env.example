# --- Metabook backend (Node.js + SQLite) ---

# PORT: Port the Express API server listens on (default 4000).
PORT="4000"

# JWT_SECRET: Secret used to sign auth tokens. Set a strong random value in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# --- Optional: Gemini AI (only if AI features are used) ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
